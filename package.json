{
  "name": "manabandhu-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "frontend-web",
    "backend"
  ],
  "scripts": {
    "mobile": "npm --workspace frontend run start",
    "web": "npm --workspace frontend-web run dev",
    "frontend": "npm run mobile",
    "backend": "cd backend && export $(cat .env | grep -v '^#' | xargs) && ./mvnw spring-boot:run",
    "dev": "concurrently \"npm run mobile\" \"npm run backend\"",
    "dev:all": "concurrently \"npm run mobile\" \"npm run web\" \"npm run backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:web": "npm --workspace frontend-web run build",
    "build:backend": "cd backend && ./mvnw clean package"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.26",
    "expo": "^54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-router": "^6.0.23"
  }
}
